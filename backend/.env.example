# Copy to backend/.env and fill in your values

# Supabase (required for daily email summaries; frontend uses its own config.js)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP (required for daily email summaries)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Production settings
# Comma-separated frontend URL(s) allowed by CORS (use * for local dev only)
ALLOWED_ORIGINS=https://your-frontend.netlify.app
# Secret key for /test-email and /trigger-daily-summary (send as X-Admin-Key header)
ADMIN_API_KEY=generate-a-long-random-string
# Set to false on serverless hosts that cannot run background schedulers
ENABLE_SCHEDULER=true
# PORT is set automatically by Render/Railway/Heroku
